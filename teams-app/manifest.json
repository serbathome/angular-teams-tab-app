{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "00c0513e-7bc8-4a98-bcb4-36fbed66c808",
  "name": {
    "short": "Teams Tab",
    "full": "Microsoft Teams Angular Tab"
  },
  "description": {
    "short": "Angular Teams Tab with OIDC auth",
    "full": "Angular-based Microsoft Teams tab application with Entra ID OIDC authentication."
  },
  "developer": {
    "name": "Microsoft",
    "websiteUrl": "https://teamsapp.my-cloud-lab.com",
    "privacyUrl": "https://teamsapp.my-cloud-lab.com",
    "termsOfUseUrl": "https://teamsapp.my-cloud-lab.com"
  },
  "icons": {
    "color": "color.png",
    "outline": "outline.png"
  },
  "accentColor": "#0078D4",
  "staticTabs": [
    {
      "entityId": "home",
      "name": "Home",
      "contentUrl": "https://teamsapp.my-cloud-lab.com/home",
      "websiteUrl": "https://teamsapp.my-cloud-lab.com/home",
      "scopes": ["personal"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://teamsapp.my-cloud-lab.com/tab-config",
      "canUpdateConfiguration": false,
      "scopes": ["team", "groupchat"]
    }
  ],
  "validDomains": [
    "teamsapp.my-cloud-lab.com"
  ],
  "permissions": ["identity"]
}
